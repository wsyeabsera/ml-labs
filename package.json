{
  "name": "ml-labs",
  "version": "0.2.0",
  "description": "A Claude-native ML platform — train, sweep, and ship models from your terminal",
  "private": true,
  "workspaces": ["neuron", "site"],
  "scripts": {
    "docs": "bun --cwd site run dev",
    "docs:build": "bun --cwd site run build",
    "docs:preview": "bun --cwd site run preview",
