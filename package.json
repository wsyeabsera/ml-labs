{
  "name": "ml-labs",
  "version": "1.7.1",
  "description": "A Claude-native ML platform — train, sweep, and ship models from your terminal",
  "private": true,
  "workspaces": ["neuron", "site", "cli", "dashboard"],
  "scripts": {
    "docs": "bun --cwd site run dev",
    "docs:build": "bun --cwd site run build",
    "docs:preview": "bun --cwd site run preview",
    "mcp:dev": "bun --cwd neuron run dev",
    "mcp:build": "bun --cwd neuron run build",
    "tui": "bun --cwd neuron run tui",
    "cli:build": "bun --cwd cli run build",
    "dashboard:dev": "bun --cwd dashboard run dev",
    "dashboard:build": "bun --cwd dashboard run build"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
